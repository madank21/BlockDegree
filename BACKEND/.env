# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Blockchain
BLOCKCHAIN_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/your_key
BLOCKCHAIN_PRIVATE_KEY=your_wallet_private_key
CONTRACT_ADDRESS=0x_your_deployed_contract_address
CHAIN_ID=80001

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=BlockDegree <noreply@blockdegree.com>

# Face Verification API (e.g., AWS Rekognition or custom)
FACE_API_URL=https://api.facerecognition.service
FACE_API_KEY=your_face_api_key

# OCR
OCR_CONFIDENCE_THRESHOLD=75

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Frontend
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Fraud Detection
FRAUD_SCORE_THRESHOLD=70

# QR Code
QR_BASE_URL=http://localhost:3000/verify